*---------------------------------------------------------------------*
* Z390_DNRM2 - Self-contained z390 test for DNRM2 scalar path.      *
* One file, two CSECTs, proper OS linkage. No VF instructions.       *
* All floating-point constants are IEEE 754 BFP (DC X'...').         *
* HFP is the ghost of a bad idea. We do not speak of it here.        *
*---------------------------------------------------------------------*
R0       EQU   0
R1       EQU   1
R2       EQU   2
R3       EQU   3
R4       EQU   4
R5       EQU   5
R6       EQU   6
R7       EQU   7
R8       EQU   8
R9       EQU   9
R10      EQU   10
R11      EQU   11
R12      EQU   12
R13      EQU   13
R14      EQU   14
R15      EQU   15
*
* ---- TEST HARNESS ----
*
TSTDNRM2 CSECT
         STM   R14,R12,12(R13)            Save z390 context
         LR    R12,R15                     Base = entry point
         USING TSTDNRM2,R12
         LA    R10,TSAVE                   Our save area
         ST    R13,4(,R10)                 Back-chain to z390 SA
         ST    R10,8(,R13)                 Forward-chain
         LR    R13,R10                     R13 = our SA
*
         WTO   'ZBLAS DNRM2 z390 test'
*
* ---- TEST 1: X=[3,4], N=2 -> sqrt(9+16)=5.0 ----
*
         WTO   'T1: nrm2 [3,4]=5'
         LA    R1,T1PL
         L     R15,=A(DNRM2)
         BALR  R14,R15
         CDB   0,T1EXP
         BE    T1P1
         WTO   'FAIL nrm2!=5'
         B     TST2
T1P1     WTO   'PASS nrm2=5'
*
* ---- TEST 2: N=0 -> FPR0=0.0 ----
*
TST2     DS    0H
         WTO   'T2: N=0'
         LA    R1,T2PL
         L     R15,=A(DNRM2)
         BALR  R14,R15
         CDB   0,DZERO
         BE    T2P1
         WTO   'FAIL N=0'
         B     TST3
T2P1     WTO   'PASS N=0'
*
* ---- TEST 3: N=1, X=[3] -> |3|=3.0 ----
*
TST3     DS    0H
         WTO   'T3: N=1 X=[3]'
         LA    R1,T3PL
         L     R15,=A(DNRM2)
         BALR  R14,R15
         CDB   0,T3EXP
         BE    T3P1
         WTO   'FAIL nrm2!=3'
         B     DONE
T3P1     WTO   'PASS nrm2=3'
*
* ---- DONE ----
*
DONE     DS    0H
         WTO   'DNRM2: ALL TESTS DONE'
         L     R13,4(,R13)                 Restore z390 SA
         LM    R14,R12,12(R13)             Restore z390 regs
         SR    R15,R15                     RC=0
         BR    R14
*
* ---- Test data (all doubles are IEEE 754 BFP hex) ----
*
TSAVE    DS    18F                         Our save area
         DS    0D
* BFP 0.0
DZERO    DC    X'0000000000000000'
*
* Test 1: X=[3,4], N=2, INCX=1 -> sqrt(9+16)=sqrt(25)=5
T1N      DC    F'2'
         DS    0D
T1X      DC    X'4008000000000000'         BFP 3.0
         DC    X'4010000000000000'         BFP 4.0
T1IX     DC    F'1'
         DS    0D
T1EXP    DC    X'4014000000000000'         BFP 5.0
T1PL     DC    A(T1N,T1X)
         DC    X'80',AL3(T1IX)
*
* Test 2: N=0
         DS    0D
T2N      DC    F'0'
         DS    0D
T2X      DC    X'4008000000000000'         BFP 3.0 (never touched)
T2IX     DC    F'1'
T2PL     DC    A(T2N,T2X)
         DC    X'80',AL3(T2IX)
*
* Test 3: N=1, X=[3], INCX=1 -> sqrt(9)=3
         DS    0D
T3N      DC    F'1'
         DS    0D
T3X      DC    X'4008000000000000'         BFP 3.0
T3IX     DC    F'1'
         DS    0D
T3EXP    DC    X'4008000000000000'         BFP 3.0
T3PL     DC    A(T3N,T3X)
         DC    X'80',AL3(T3IX)
         LTORG
         DROP  R12
*
* ============================================================= *
* DNRM2 - Euclidean norm (scalar only, no VF).                  *
* Parm list: N, DX, INCX (3 parms, high bit on last).           *
* Returns sqrt(sum(X(i)^2)) in FPR0.                            *
* ============================================================= *
*
DNRM2    CSECT
         STM   R14,R12,12(R13)
         LR    R12,R15
         USING DNRM2,R12
         LR    R11,R1
         SDBR  0,0                         FPR0 = 0.0
         L     R2,0(,R11)
         L     R2,0(,R2)                   N
         LTR   R2,R2
         BNP   DNR@RT
         L     R4,4(,R11)
         L     R5,8(,R11)
         L     R5,0(,R5)                   INCX
         SLA   R5,3                        byte stride
         LTR   R5,R5
         BNM   DNR@SL
         LR    R0,R2
         BCTR  R0,0
         MSR   R0,R5
         LCR   R0,R0
         AR    R4,R0
DNR@SL   DS    0H
         LR    R8,R2
DNR@S1   DS    0H
         LD    2,0(,R4)
         MDBR  2,2                         FPR2 = X(i)^2
         ADBR  0,2                         FPR0 += X(i)^2
         AR    R4,R5
         BCT   R8,DNR@S1
         SQDBR 0,0                         FPR0 = sqrt(sum)
DNR@RT   DS    0H
         LM    R14,R12,12(R13)
         BR    R14
         LTORG
         END   TSTDNRM2
