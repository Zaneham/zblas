*---------------------------------------------------------------------*
* Z390_DCOPY - Self-contained z390 test for DCOPY scalar path.       *
* One file, two CSECTs, proper OS linkage. No VF instructions.       *
*---------------------------------------------------------------------*
R0       EQU   0
R1       EQU   1
R2       EQU   2
R3       EQU   3
R4       EQU   4
R5       EQU   5
R6       EQU   6
R7       EQU   7
R8       EQU   8
R9       EQU   9
R10      EQU   10
R11      EQU   11
R12      EQU   12
R13      EQU   13
R14      EQU   14
R15      EQU   15
*
* ---- TEST HARNESS ----
*
TSTDCOPY CSECT
         STM   R14,R12,12(R13)            Save z390 context
         LR    R12,R15                     Base = entry point
         USING TSTDCOPY,R12
         LA    R10,TSAVE                   Our save area
         ST    R13,4(,R10)                 Back-chain to z390 SA
         ST    R10,8(,R13)                 Forward-chain
         LR    R13,R10                     R13 = our SA
*
         WTO   'ZBLAS DCOPY z390 test'
*
* ---- TEST 1: X=[1,2,3], Y=[0,0,0], N=3, INCX=1, INCY=1 ----
*
         WTO   'T1: copy [1,2,3] -> Y'
         MVC   T1Y(24),T1YINI             Reset Y to all zeros
         LA    R1,T1PL
         L     R15,=A(DCOPY)
         BALR  R14,R15
* Verify Y(1) = 1.0
         LD    0,T1Y
         CDB   0,T1E1
         BE    T1P1
         WTO   'FAIL Y1!=1.0'
         B     T1C2
T1P1     WTO   'PASS Y1=1.0'
T1C2     DS    0H
* Verify Y(2) = 2.0
         LD    0,T1Y+8
         CDB   0,T1E2
         BE    T1P2
         WTO   'FAIL Y2!=2.0'
         B     T1C3
T1P2     WTO   'PASS Y2=2.0'
T1C3     DS    0H
* Verify Y(3) = 3.0
         LD    0,T1Y+16
         CDB   0,T1E3
         BE    T1P3
         WTO   'FAIL Y3!=3.0'
         B     TST2
T1P3     WTO   'PASS Y3=3.0'
*
* ---- TEST 2: N=0 -> no crash, Y unchanged ----
*
TST2     DS    0H
         WTO   'T2: N=0 no crash'
         MVC   T2Y(8),T2YINI              Reset Y to sentinel
         LA    R1,T2PL
         L     R15,=A(DCOPY)
         BALR  R14,R15
         WTO   'PASS N=0'
*
* ---- DONE ----
*
         WTO   'DCOPY: ALL TESTS DONE'
         L     R13,4(,R13)                Restore z390 SA
         LM    R14,R12,12(R13)            Restore z390 regs
         SR    R15,R15                    RC=0
         BR    R14
*
* ---- Test data ----
*
TSAVE    DS    18F                        Our save area
         DS    0D
* Test 1 data
T1N      DC    F'3'
T1X      DC    X'3FF0000000000000'        BFP 1.0
         DC    X'4000000000000000'        BFP 2.0
         DC    X'4008000000000000'        BFP 3.0
T1IX     DC    F'1'
T1Y      DC    X'0000000000000000'        BFP 0.0
         DC    X'0000000000000000'        BFP 0.0
         DC    X'0000000000000000'        BFP 0.0
T1IY     DC    F'1'
T1YINI   DC    X'0000000000000000'        BFP 0.0
         DC    X'0000000000000000'        BFP 0.0
         DC    X'0000000000000000'        BFP 0.0
T1E1     DC    X'3FF0000000000000'        BFP 1.0
T1E2     DC    X'4000000000000000'        BFP 2.0
T1E3     DC    X'4008000000000000'        BFP 3.0
T1PL     DC    A(T1N,T1X,T1IX,T1Y)
         DC    X'80',AL3(T1IY)
         DS    0D
* Test 2 data
T2N      DC    F'0'
T2X      DC    X'4014000000000000'        BFP 5.0 (should not touch Y)
T2IX     DC    F'1'
T2Y      DC    X'4024000000000000'        BFP 10.0 (sentinel, must stay)
T2IY     DC    F'1'
T2YINI   DC    X'4024000000000000'        BFP 10.0
T2PL     DC    A(T2N,T2X,T2IX,T2Y)
         DC    X'80',AL3(T2IY)
         LTORG
         DROP  R12
*
* ============================================================= *
* DCOPY - scalar only (no VF, no STFLE, z390 safe)              *
* ============================================================= *
*
DCOPY    CSECT
         STM   R14,R12,12(R13)
         LR    R12,R15
         USING DCOPY,R12
         LR    R11,R1
         L     R2,0(,R11)
         L     R2,0(,R2)                  N
         LTR   R2,R2
         BNP   DCP@RT
         L     R4,4(,R11)                 DX
         L     R5,8(,R11)
         L     R5,0(,R5)                  INCX
         L     R6,12(,R11)                DY
         L     R7,16(,R11)
         L     R7,0(,R7)                  INCY
         SLA   R5,3
         SLA   R7,3
         LTR   R5,R5
         BNM   DCP@AY
         LR    R0,R2
         BCTR  R0,0
         MSR   R0,R5
         LCR   R0,R0
         AR    R4,R0
DCP@AY   DS    0H
         LTR   R7,R7
         BNM   DCP@SL
         LR    R0,R2
         BCTR  R0,0
         MSR   R0,R7
         LCR   R0,R0
         AR    R6,R0
DCP@SL   DS    0H
         LR    R8,R2
DCP@S1   DS    0H
         LD    2,0(,R4)
         STD   2,0(,R6)
         AR    R4,R5
         AR    R6,R7
         BCT   R8,DCP@S1
DCP@RT   DS    0H
         LM    R14,R12,12(R13)
         BR    R14
         LTORG
         END   TSTDCOPY
